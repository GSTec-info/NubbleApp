{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "@components": ["src/components"],
      "@hooks": ["src/hooks"],
      "@routes": ["src/routes"],
      "@screens": ["src/screens"],
      "@theme": ["src/theme"],
      "@domain": ["src/domain"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
